# ==========================================
# LLMプロバイダー設定（いずれか1つを使用）
# ==========================================

# --- OpenAI (クラウド) ---
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Anthropic Claude (クラウド) ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google Gemini (クラウド) ---
# https://aistudio.google.com/apikey
GOOGLE_AI_API_KEY=AIzaxxxxxxxxxxxxxxxxxxxxxxxx

# --- Ollama (ローカル) ---
# APIキー不要。Ollamaをローカルで起動するだけでOK。
# config.json の ollama_base_url / ollama_model で設定。

# ==========================================
# 通知設定
# ==========================================

# --- Slack通知 ---
# https://api.slack.com/apps → Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXXX/XXXXX/XXXXX

# --- メール通知 ---
# Gmailの場合: アプリパスワードを使用 (https://myaccount.google.com/apppasswords)
EMAIL_SMTP_USER=your-email@gmail.com
EMAIL_SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ==========================================
# Google Sheets連携（任意）
# ==========================================
# Google Cloud サービスアカウントのJSONキー（中身を丸ごと貼り付け）
GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}
